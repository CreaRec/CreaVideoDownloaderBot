{
  "name": "telegram-video-downloader",
  "version": "0.1.0",
  "description": "Download Telegram videos re-sent to a private bot chat using GramJS.",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "login": "tsx src/cli/login.ts",
    "validate:settings": "tsx src/cli/validate-settings.ts",
    "test": "node --import tsx --test \"tests/**/*.test.ts\""
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "input": "^1.0.1",
    "telegraf": "^4.16.3",
    "telegram": "^2.26.22",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
